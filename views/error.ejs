<%- include('components/header') %>

<div class="h-screen w-full flex items-center justify-center bg-gray-50 dark:bg-darkbg">
    <div class="text-center p-8 bg-white dark:bg-darkcard rounded-2xl shadow-xl max-w-lg w-full border border-gray-100 dark:border-gray-800">
        <div class="w-20 h-20 bg-red-100 dark:bg-red-500/20 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h1 class="text-3xl font-bold mb-2">Something went wrong</h1>
        <p class="text-gray-500 dark:text-gray-400 mb-6 bg-gray-100 dark:bg-gray-800 p-4 rounded-lg text-sm text-left font-mono overflow-x-auto"><%= error %></p>
        <a href="/dashboard" class="inline-block bg-primary text-white px-6 py-2.5 rounded-full font-medium hover:bg-indigo-600 transition-colors">
            Return to Dashboard
        </a>
    </div>
</div>

<%- include('components/footer') %>
