<%- include('components/header') %>
<%- include('components/sidebar') %>

<div class="flex-1 p-6 lg:p-10 relative">
    <!-- Top Bar -->
    <header class="flex justify-between items-center mb-10">
        <div>
            <h2 class="text-3xl font-extrabold tracking-tight">Overview</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-1">Hello <%= user.name || 'User' %>, here is your performance today.</p>
        </div>
        <a href="/habits" class="bg-gradient-to-r from-primary to-secondary text-white px-6 py-2.5 rounded-full font-medium shadow-lg hover:shadow-primary/50 transform hover:-translate-y-0.5 transition-all">
            <i class="bi bi-plus-lg mr-1"></i> New Habit
        </a>
    </header>

    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <!-- Card 1 -->
        <div class="bg-white dark:bg-darkcard rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800 flex items-center justify-between group hover:shadow-md transition-shadow">
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-1">Total Habits</p>
                <h3 class="text-3xl font-bold"><%= stats.totalHabits %></h3>
            </div>
            <div class="w-12 h-12 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                <i class="bi bi-list-task"></i>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white dark:bg-darkcard rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800 flex items-center justify-between group hover:shadow-md transition-shadow">
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-1">Completed Today</p>
                <h3 class="text-3xl font-bold"><%= stats.completedToday %> / <%= stats.totalHabits %></h3>
            </div>
            <div class="w-12 h-12 rounded-full bg-green-50 dark:bg-green-900/20 text-green-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                <i class="bi bi-check2-circle"></i>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white dark:bg-darkcard rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800 flex items-center justify-between group hover:shadow-md transition-shadow">
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-1">Daily Success Rate</p>
                <h3 class="text-3xl font-bold"><%= stats.completionPercentage %>%</h3>
            </div>
            <div class="w-12 h-12 rounded-full bg-purple-50 dark:bg-purple-900/20 text-purple-500 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
        </div>
    </div>

    <!-- Main Content Area Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Column: Habits List -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white dark:bg-darkcard rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                    <i class="bi bi-calendar-check text-primary"></i> Today's Schedule
                </h3>
                
                <% if(habits.length === 0) { %>
                    <div class="text-center py-10">
                        <div class="inline-flex w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 items-center justify-center text-gray-400 mb-4 text-2xl">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <p class="text-gray-500 dark:text-gray-400">You don't have any habits yet.</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4">
                        <% habits.forEach(habit => { %>
                            <div class="flex items-center justify-between p-4 rounded-xl border border-gray-100 dark:border-gray-700 <%= habit.isCompletedToday ? 'bg-gray-50 dark:bg-gray-800/50 opacity-70' : 'bg-white dark:bg-gray-800 shadow-sm' %> hover:border-primary/30 transition-all">
                                <div class="flex items-center gap-4">
                                    <% if(habit.isCompletedToday) { %>
                                        <div class="flex flex-col items-center">
                                            <button disabled class="w-8 h-8 rounded-full border-2 bg-green-500 border-green-500 text-white flex items-center justify-center cursor-not-allowed shadow-md">
                                                <i class="bi bi-check-lg text-xl font-bold"></i>
                                            </button>
                                            <span class="text-[10px] text-green-500 font-bold mt-1 uppercase tracking-wider">Completed</span>
                                        </div>
                                    <% } else { %>
                                        <div class="flex flex-col items-center">
                                            <button class="log-btn w-8 h-8 rounded-full border-2 border-gray-300 dark:border-gray-600 hover:border-primary hover:bg-primary/10 text-transparent hover:text-primary flex items-center justify-center transition-all group" 
                                                    data-id="<%= habit.id %>" 
                                                    data-status="completed">
                                                <i class="bi bi-check-lg text-xl font-bold opacity-0 group-hover:opacity-100 transition-opacity"></i>
                                            </button>
                                            <span class="text-[10px] text-gray-400 font-bold mt-1 uppercase tracking-wider">Pending</span>
                                        </div>
                                    <% } %>
                                    <div>
                                        <h4 class="font-bold text-lg <%= habit.isCompletedToday ? 'line-through text-gray-400' : '' %>"><%= habit.name %></h4>
                                        <div class="flex items-center gap-3 text-xs text-gray-500 mt-1">
                                            <span class="px-2 py-1 rounded-md bg-gray-100 dark:bg-gray-700"><%= habit.category %></span>
                                            <span class="flex items-center text-orange-500 font-medium">
                                                <i class="bi bi-fire mr-1"></i> <%= habit.streak || 0 %> Day Streak
                                            </span>
                                            <% if (habit.reminderTime) { %>
                                                <span><i class="bi bi-clock mr-1"></i> <%= habit.reminderTime %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

            <!-- Chart Card -->
            <div class="bg-white dark:bg-darkcard rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-800">
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                    <i class="bi bi-bar-chart-fill text-primary"></i> Performance Trend
                </h3>
                <div class="h-64">
                    <canvas id="performanceChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Right Column: AI Predictions -->
        <div class="space-y-6">
            <div class="bg-gradient-to-br from-indigo-900 to-purple-900 rounded-2xl p-1 relative overflow-hidden shadow-lg">
                <!-- Decorative blurred circles -->
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-primary/40 rounded-full blur-2xl"></div>
                <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-secondary/40 rounded-full blur-2xl"></div>
                
                <div class="bg-slate-900/80 backdrop-blur-md rounded-xl p-6 relative z-10 h-full border border-white/10">
                    <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                        <i class="bi bi-cpu-fill text-secondary"></i> AI Consistency Oracle
                    </h3>
                    
                    <% if(habits.length === 0) { %>
                        <p class="text-gray-400 text-sm">Add some habits to receive AI-powered insights on your behavioral patterns.</p>
                    <% } else { %>
                        <div class="space-y-5">
                            <% habits.forEach(habit => { %>
                                <div class="p-4 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                                    <div class="flex justify-between items-center mb-2">
                                        <h4 class="font-semibold text-gray-100 truncate w-3/4"><%= habit.name %></h4>
                                        <% 
                                            let pColor = 'text-green-400';
                                            if (habit.prediction.probability > 40) pColor = 'text-yellow-400';
                                            if (habit.prediction.probability > 70) pColor = 'text-red-400';
                                        %>
                                        <span class="text-sm font-bold <%= pColor %>"><%= habit.prediction.probability %>% Risk</span>
                                    </div>
                                    
                                    <!-- Progress Bar -->
                                    <div class="w-full bg-gray-700 rounded-full h-1.5 mb-2 overflow-hidden">
                                        <div class="bg-gradient-to-r from-green-400 via-yellow-400 to-red-500 h-1.5 rounded-full shadow-[0_0_10px_rgba(255,255,255,0.3)]" style="width: <%= habit.prediction.probability %>%"></div>
                                    </div>
                                    
                                    <p class="text-xs text-gray-400 leading-relaxed"><%= habit.prediction.insights %></p>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    // AJAX for Logging Habits
    document.querySelectorAll('.log-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const el = e.currentTarget;
            const habitId = el.getAttribute('data-id');
            const status = el.getAttribute('data-status');
            const date = new Date().toISOString().split('T')[0];

            try {
                const res = await fetch('/habits/log', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ habitId, status, date })
                });

                if (res.ok) {
                    window.location.reload(); // Quick reload to update stats & UI
                }
            } catch (err) {
                console.error(err);
                alert("Error logging habit");
            }
        });
    });

    // Real-Time Reminder System (Phase 2)
    const rawHabits = <%- JSON.stringify(habits) %>;
    const notifiedHabits = new Set(); // Prevent spamming notifications
    
    // Request Browser Notification Permission
    if ("Notification" in window && Notification.permission !== "denied") {
        Notification.requestPermission();
    }

    setInterval(() => {
        const now = new Date();
        const currentHours = String(now.getHours()).padStart(2, '0');
        const currentMinutes = String(now.getMinutes()).padStart(2, '0');
        const currentTimeString = `${currentHours}:${currentMinutes}`; // HH:MM

        rawHabits.forEach(habit => {
            if (habit.reminderTime === currentTimeString && !habit.isCompletedToday && !notifiedHabits.has(habit.id)) {
                // Time matched! Trigger Notification
                notifiedHabits.add(habit.id); // Mark as notified for this session

                const title = "Habit Reminder 🔔";
                const body = `Time to complete: ${habit.name}`;

                // 1. Browser Notification
                if (Notification.permission === "granted") {
                    new Notification(title, { body: body, icon: '/favicon.ico' });
                }

                // 2. Fallback / Additional Toast UI
                const toast = document.createElement('div');
                toast.className = `fixed bottom-4 right-4 bg-white dark:bg-darkcard p-4 rounded-xl shadow-2xl border-l-4 border-primary z-50 transform translate-y-20 opacity-0 transition-all duration-500`;
                toast.innerHTML = `
                    <div class="flex items-start gap-4">
                        <div class="text-primary text-2xl"><i class="bi bi-bell-fill"></i></div>
                        <div>
                            <h4 class="font-bold text-gray-900 dark:text-white">${title}</h4>
                            <p class="text-sm text-gray-600 dark:text-gray-300">${body}</p>
                        </div>
                        <button class="text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()"><i class="bi bi-x"></i></button>
                    </div>
                `;
                document.body.appendChild(toast);
                
                // Animate in
                setTimeout(() => {
                    toast.classList.remove('translate-y-20', 'opacity-0');
                }, 100);

                // Auto remove after 10s
                setTimeout(() => {
                    toast.classList.add('translate-y-20', 'opacity-0');
                    setTimeout(() => toast.remove(), 500);
                }, 10000);
                
                // Play simple generic beep sound via Web Audio API
                try {
                    const ctx = new (window.AudioContext || window.webkitAudioContext)();
                    const osc = ctx.createOscillator();
                    osc.connect(ctx.destination);
                    osc.frequency.value = 800;
                    osc.start();
                    setTimeout(() => osc.stop(), 200);
                } catch(e) {}
            }
        });
    }, 30000); // Check every 30 seconds

    // Chart.js Setup
    document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('performanceChart').getContext('2d');
        
        // Gradient for line chart
        let gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(99, 102, 241, 0.5)'); // primary color with opacity
        gradient.addColorStop(1, 'rgba(99, 102, 241, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Overall Completion %',
                    data: [65, 59, 80, 81, 56, 55, 40], // Dummy aesthetic data since we need historical aggregation
                    borderColor: '#6366f1',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: '#ec4899',
                    pointBorderColor: '#fff',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: '#ec4899',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        grid: {
                            color: 'rgba(156, 163, 175, 0.1)'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    });
</script>

<%- include('components/footer') %>
